{
  "datasets": [
    {
      "name": "d344d426",
      "displayName": "NYC Taxi Trips",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  samples.nyctaxi.trips"
      ],
      "columns": [
        {
          "displayName": "Pickup Date",
          "description": "Pickup datetime truncated to day for daily trends",
          "expression": "DATE_TRUNC('day', `tpep_pickup_datetime`)"
        },
        {
          "displayName": "Pickup Hour",
          "description": "Hour of day (0-23) for hourly activity patterns",
          "expression": "HOUR(`tpep_pickup_datetime`)"
        },
        {
          "displayName": "Day of Week",
          "description": "Day name for weekly patterns",
          "expression": "DATE_FORMAT(`tpep_pickup_datetime`, 'EEEE')"
        },
        {
          "displayName": "Trip Duration (min)",
          "description": "Trip duration in minutes",
          "expression": "ROUND((UNIX_TIMESTAMP(`tpep_dropoff_datetime`) - UNIX_TIMESTAMP(`tpep_pickup_datetime`)) / 60, 1)"
        },
        {
          "displayName": "Cost per Mile",
          "description": "Fare per mile traveled",
          "expression": "CASE WHEN `trip_distance` > 0 THEN ROUND(`fare_amount` / `trip_distance`, 2) ELSE NULL END"
        },
        {
          "displayName": "Distance Bin (mi)",
          "description": "Trip distance rounded to nearest mile for charting",
          "expression": "ROUND(`trip_distance`, 0)"
        }
      ]
    }
  ],
